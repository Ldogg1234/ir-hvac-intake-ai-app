{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "main",
      "public": "web-form",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/intake",
          "run": {
            "serviceId": "intakepublic",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/pmSearch",
          "run": {
            "serviceId": "pmsearchpublic",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/clockIn",
          "run": {
            "serviceId": "clockinpublic",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/getTechCalendar",
          "run": {
            "serviceId": "gettechcalendar",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/searchJobByAddress",
          "run": {
            "serviceId": "searchjobbyaddress",
            "region": "us-central1"
          }
        },
        {
          "source": "/clock-in",
          "destination": "/clock-in.html"
        },
        {
          "source": "/onboarding",
          "destination": "/onboarding.html"
        },
        {
          "source": "/admin-onboarding",
          "destination": "/ops/admin-onboarding.html"
        },
        {
          "source": "/api/submitOnboarding",
          "run": {
            "serviceId": "submitonboardinghttp",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ops/update-lead",
          "run": {
            "serviceId": "updateleadops",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ops/delete-lead",
          "run": {
            "serviceId": "deleteleadops",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ops/retry-sync",
          "run": {
            "serviceId": "retryintake",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ops/approve-report",
          "run": {
            "serviceId": "approvereport",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/ops/reply-email",
          "run": {
            "serviceId": "replytoemailhttp",
            "region": "us-central1"
          }
        },
        {
          "source": "/po-workbench",
          "destination": "/po-workbench.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "app",
      "public": "build/web",
      "headers": [
        {
          "source": "flutter_bootstrap.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "cash-flow",
      "public": "web-form",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/forensic-audit",
          "destination": "/forensic-audit-form.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}