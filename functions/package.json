{
  "name": "ir-hvac-intake-ai-functions",
  "version": "1.0.0",
  "description": "HVAC lead intake automation for Immediate Response HVAC",
  "main": "lib/index.js",
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "logs": "firebase functions:log",
    "deploy": "firebase deploy --only functions --project immediate-response-ai-b18b8",
    "lint": "eslint --ext .ts src/",
    "lint:fix": "eslint --ext .ts src/ --fix"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.2",
    "@google-cloud/vertexai": "^1.10.0",
    "@google-cloud/video-intelligence": "^6.2.1",
    "@google-cloud/vision": "^5.3.4",
    "@google/generative-ai": "^0.24.1",
    "@sparticuz/chromium": "^147.0.2",
    "axios": "^1.16.0",
    "csv-parser": "^3.2.1",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.2.5",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "intuit-oauth": "^4.2.2",
    "mammoth": "^1.12.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "puppeteer": "^24.43.1",
    "puppeteer-core": "^24.42.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.9",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.3",
    "@types/uuid": "^9.0.7",
    "dotenv": "^16.6.1",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
